# ============================================================================
# Database Configuration
# ============================================================================
# PostgreSQL connection string for MediGuide AI
# Format: postgresql://[user[:password]@][netloc][:port][/dbname][?param1=value1&...]
# Local development example: postgresql://postgres:password@localhost:5432/mediguide_ai
DATABASE_URL=postgresql://user:password@localhost:5432/mediguide_ai

# ============================================================================
# NextAuth Configuration
# ============================================================================
# Application URL for NextAuth callbacks
NEXTAUTH_URL=http://localhost:3000

# Secret key for signing tokens (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# ============================================================================
# Google OAuth Configuration (Optional)
# ============================================================================
# Get these from Google Cloud Console: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================================================
# Gemini API Configuration
# ============================================================================
# Get API key from Google AI Studio: https://makersuite.google.com/app/apikey
NEXT_PUBLIC_GEMINI_API_KEY=your-gemini-api-key

# ============================================================================
# Environment Configuration
# ============================================================================
# Development, staging, or production
NODE_ENV=development

# ============================================================================
# Optional: Analytics & Monitoring
# ============================================================================
# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Vercel Analytics Token (if using Vercel)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your-analytics-id

